{
  "protected_paths": [
    "/etc",
    "/usr/bin",
    "/usr/sbin",
    "/usr/local/bin",
    "/usr/local/sbin",
    "/lib",
    "/lib64",
    "/boot",
    "/root/.ssh"
  ],
  "exempt_processes": [
    "dpkg",
    "apt",
    "apt-get",
    "yum",
    "dnf",
    "pacman",
    "systemd",
    "systemctl",
    "install",
    "git",
    "make",
    "gcc",
    "clang",
    "zig"
  ],
  "log_file": "/var/log/guardian_shield.log",
  "verbose": true
}
