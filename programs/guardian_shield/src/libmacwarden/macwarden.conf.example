# macwarden configuration file
# Format: key=value (one per line)
# Lines starting with # are comments

# Enable/disable protection (true/false)
enabled=true

# Verbose logging for debugging
verbose=false

# Protected paths - these cannot be modified
protected=/Users/director/work
protected=/Users/director/websites
protected=/Users/director/.ssh
protected=/Users/director/.gnupg
protected=/Users/director/.aws

# Whitelisted paths - always allowed (system needs these)
whitelist=/tmp
whitelist=/private/tmp
whitelist=/var/folders
whitelist=/Library/Caches
whitelist=/Users/director/Library/Caches
whitelist=/Users/director/.cache

# Self-preservation patterns - prevent removal of warden itself
self_preserve=libmacwarden
self_preserve=macwarden.conf
self_preserve=warden
