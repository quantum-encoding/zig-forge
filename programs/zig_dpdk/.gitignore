programs/chronos_engine/src/chronos*
programs/chronos_engine/src/cognitive-watcher
programs/chronos_engine/src/cognitive-watcher-v2
!programs/chronos_engine/src/*.zig
programs/stratum_engine_claude/test_*
!programs/stratum_engine_claude/test_*.zig

