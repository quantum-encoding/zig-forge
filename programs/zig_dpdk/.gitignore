# Prebuilt binaries (should be built from source)
programs/*/bin/
programs/*/bin_prebuilt/
programs/**/bin/
programs/**/bin_prebuilt/

# Compiled test binaries and artifacts
programs/*/tests/main
programs/**/tests/main
test_*
!test_*.zig

# Go binaries in financial_engine
programs/financial_engine/go-bridge/account-check
